{
  "name": "syswidget",
  "version": "1.0.4",
  "description": "Application de bureau pour surveiller CPU, RAM, disques, réseau et GPU en temps réel",
  "author": "CA_Dev",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "systeminformation": "^5.32.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "type": "module",
  "scripts": {
    "probe": "tsx src/probe.ts",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').copyFileSync('electron/package.json','dist-electron/package.json')\"",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "dev:electron": "yarn build:electron && yarn build:renderer && electron .",
    "dist": "yarn build:electron && yarn build:renderer && electron-builder --win",
    "release": "yarn build:electron && yarn build:renderer && electron-builder --win --publish always"
  },
  "build": {
    "appId": "CA_dev.syswidget",
    "productName": "SysWidget",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "differentialPackage": false
    }
  },
  "publish": {
    "provider": "github",
    "owner": "cedricauneau-ship-it",
    "repo": "Widget-sys",
    "draft": false
  }
}
